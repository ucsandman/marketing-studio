# Path to blender.exe if Blender is not on PATH (phase 3 feeder)
BLENDER_PATH=C:/Program Files/Blender Foundation/Blender X.Y/blender.exe
# ElevenLabs (audio feeder: voiceover + music)
ELEVENLABS_API_KEY=sk_your_key_here
# Optional; defaults to the Rachel premade voice
ELEVENLABS_VOICE_ID=
# X API v2 bearer token (results feedback loop: scripts/fetch-results.mjs);
# missing token = exit 2, X posts marked unavailable in results.json
X_BEARER_TOKEN=
